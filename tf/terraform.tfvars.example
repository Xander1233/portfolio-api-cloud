project                              = "portfolio"
environment                          = "prod"
aws_region                           = "eu-central-1"
aws_application                      = "arn:aws:resource-groups:eu-central-1:111122223333:group/Portfolio/12345678901234567890"

cf_api_token                         = "cloudflare-token"
cf_dns_zone                          = "example.com"
api_domain_name                      = "api.example.com"
public_domain_name                   = "example.com"

public_bucket_name                   = "example-public-bucket"
public_origin_access_control_id      = "E1234567890ABC"
api_web_acl_name                     = "CreatedByCloudFront-api"
public_web_acl_name                  = "CreatedByCloudFront-public"

app_image_uri                        = "ghcr.io/owner/portfolio-api:v1.0.0"
instance_type                        = "t3.micro"
ami_id_override                      = null
preferred_subnet_id                  = null
app_port                             = 80

app_config_s3_bucket_name            = "example-config-bucket"
app_config_s3_prefix                 = "app/portfolio-api/config"
app_config_s3_object_key             = "config.toml"

secrets_arns                         = ["arn:aws:secretsmanager:eu-central-1:111122223333:secret:prod/portfolio/api"]
dynamodb_arns                        = ["arn:aws:dynamodb:eu-central-1:111122223333:table/portfolio"]

alert_email                          = "alerts@example.com"
health_check_path                    = "/health"
health_lambda_image_tag              = "latest"

github_repository                    = "owner/repo"
github_oidc_branches                 = ["main"]
